DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# 数据库（由 django_proxy 项目管理，网关包不读取以下变量）
# 三选一，默认 SQLite，无需配置
# DATABASE_URL=postgresql://user:pass@localhost:5432/gateway
# DATABASE_URL=mysql://user:pass@localhost:3306/gateway
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=gateway
# DJANGO_DB_USER=user
# DJANGO_DB_PASSWORD=pass
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432
# DJANGO_DB_CONN_MAX_AGE=60

PROXY_FORWARD_MODE=stream
PROXY_WEBSOCKET_ENABLED=true
PROXY_CONNECT_TIMEOUT=10
PROXY_READ_TIMEOUT=300
# HTTPS upstream: verify cert (default). Set false if using IP URL without matching cert.
# PROXY_SSL_VERIFY=false
# PROXY_SSL_CA_BUNDLE=/path/to/ca.pem
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_CONCURRENCY=5
LOG_RETENTION_DAYS=7

REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
LOG_TO_FILE=true
PATCH_PRINT=true
